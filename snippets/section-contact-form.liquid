{% comment %}
  /**
   * @param {object} section - section object
   * @param {string} color_scheme - color scheme
   * @param {boolean} narrow_column - narrow column
   * @param {string} title - title
   * @param {string} text - text
   * @param {string} heading_position - heading position
   * @param {string} heading_size - heading size
   * @param {object} customer - customer object
   * @param {boolean} show_phone - show phone
   */
{% endcomment %}

<div class="index-section newsletter-{{ section.id }} color-scheme-{{ color_scheme }}">
  {%- if color_scheme != 'none' -%}
    {%- render 'color-scheme-texture', color_scheme: color_scheme -%}
  {%- endif -%}
  <div class="page-width{% if narrow_column %} page-width--narrow{% endif %}">
    {%- if title != blank or text != blank -%}
      <div class="section-header text-{{ heading_position }}">
        {%- if title != blank -%}
          <h2 class="section-header__title {{ heading_size }}">
            {{ title }}
          </h2>
        {%- endif -%}
        {%- if text != blank -%}
          <div class="rte section-header__rte clearfix">{{ text }}</div>
        {%- endif -%}
      </div>
    {% endif %}

    <div class="form-vertical">
      {%- assign form_id = 'contact-' | append: section.id -%}
      {%- form 'contact', id: form_id -%}
        {%- if form.posted_successfully? -%}
          <p class="note note--success">
            {{ 'info.contact_confirmation' | t }}
          </p>
        {%- endif -%}

        {{ form.errors | default_errors }}

        <div class="grid grid--small clearfix">
          <div class="grid__item medium-up--one-half">
            <label for="ContactFormName-{{ section.id }}">Full Name</label>
            <input
              type="text"
              id="ContactFormName-{{ section.id }}"
              class="input-full"
              name="contact[name]"
              autocapitalize="words"
              placeholder="e.g Juan Dela Cruz"
              value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
            >
          </div>

          <div class="grid__item medium-up--one-half">
            <label for="ContactFormEmail-{{ section.id }}">{{ 'labels.email' | t }}</label>
            <input
              type="email"
              id="ContactFormEmail-{{ section.id }}"
              class="input-full"
              name="contact[email]"
              autocorrect="off"
              autocapitalize="off"
              placeholder="e.g juandelacruz@gmail.com"
              value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
            >
          </div>
        </div>

        {%- if show_phone -%}
          <label for="ContactFormPhone-{{ section.id }}">{{ 'labels.phone_number' | t }}</label>
          <input
            type="tel"
            id="ContactFormPhone-{{ section.id }}"
            class="input-full"
            name="contact[phone]"
            pattern="[0-9\-]*"
            placeholder="e.g +63 (912)-345-6789"
            value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
          >
        {%- endif -%}

        <label for="ContactFormMessage-{{ section.id }}">{{ 'labels.message' | t }}</label>
        <textarea
          rows="5"
          id="ContactFormMessage-{{ section.id }}"
          class="input-full"
          name="contact[body]"
        >{% if form.body %}{{ form.body }}{% endif %}</textarea>

        <label for="contact-form-submit-{{ section.id }}" class="visually-hidden">{{ 'actions.send' | t }}</label>
        <button type="submit" id="contact-form-submit-{{ section.id }}" class="btn">SEND A MESSAGE</button>

        {% comment %}
          Remove the following three lines of code to remove the note
          about being protected by Google's reCAPTCHA service.
          By removing it, the small reCAPTCHA widget will appear in the
          bottom right corner of the page.
        {% endcomment %}

        <p>
          This site is secured with CAPTCHA, and our use of the service is governed by our
          <u><a href="/pages/privacy-policy">Privacy Policy</a></u> and
          <u><a href="/pages/terms-and-condition">Terms of Service</a></u
          >.
        </p>
      {%- endform -%}
    </div>
  </div>
</div>
