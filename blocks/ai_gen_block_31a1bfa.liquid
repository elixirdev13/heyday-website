{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-performance-wellness-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-performance-wellness-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-performance-wellness-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-performance-wellness-kicker-{{ ai_gen_id }} {
    font-size: {{ block.settings.kicker_size }}px;
    color: {{ block.settings.kicker_color }};
    margin: 0 0 {{ block.settings.kicker_spacing }}px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-performance-wellness-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    font-weight: 500;
    line-height: 1.2;
    font-family: "MajesticKingdome";
  }

  .ai-performance-wellness-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0 0 {{ block.settings.subheading_spacing }}px;
    font-weight: 400;
    line-height: 1.5;
  }

  .ai-performance-wellness-body-{{ ai_gen_id }} {
    font-size: {{ block.settings.body_size }}px;
    color: {{ block.settings.body_color }};
    line-height: 1.6;
    margin-bottom: {{ block.settings.body_spacing }}px;
  }

  .ai-performance-wellness-features-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.feature_gap }}px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ai-performance-wellness-feature-{{ ai_gen_id }} {
    text-align: {{ block.settings.feature_alignment }};
    padding: {{ block.settings.feature_padding }}px;
    background-color: {{ block.settings.feature_background }};
    border-radius: {{ block.settings.feature_border_radius }}px;
    border: {{ block.settings.feature_border_width }}px solid {{ block.settings.feature_border_color }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-performance-wellness-feature-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
    box-shadow: 0 {{ block.settings.hover_shadow }}px {{ block.settings.hover_shadow | times: 2 }}px rgba(0, 0, 0, 0.1);
  }

  .ai-performance-wellness-icon-wrapper-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: auto;
    margin: 0 auto {{ block.settings.icon_spacing }}px;
    background-color: {{ block.settings.icon_background }};
    border-radius: {{ block.settings.icon_border_radius }}px;
    border: {{ block.settings.icon_border_width }}px solid {{ block.settings.icon_border_color }};
  }

  .ai-performance-wellness-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    object-fit: contain;
  }

  .ai-performance-wellness-icon-svg-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size | times: 0.6 }}px;
    height: {{ block.settings.icon_size | times: 0.6 }}px;
  }

  .ai-performance-wellness-icon-svg-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.icon_color }};
  }

  .ai-performance-wellness-feature-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.feature_title_size }}px;
    color: {{ block.settings.feature_title_color }};
    margin: 0 0 {{ block.settings.feature_title_spacing }}px;
    font-weight: 600;
    line-height: 1.3;
  }

  .ai-performance-wellness-feature-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.feature_description_size }}px;
    color: {{ block.settings.feature_description_color }};
    margin: 0;
    line-height: 1.5;
  }

  @media screen and (max-width: 768px) {
    .ai-performance-wellness-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.7 }}px 0 {{ block.settings.section_padding_bottom | times: 0.7 }}px;
    }

    .ai-performance-wellness-container-{{ ai_gen_id }} {
      padding: 0 16px;
    }

    .ai-performance-wellness-features-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.feature_gap | times: 0.8 }}px;
    }

    .ai-performance-wellness-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-performance-wellness-icon-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }

    .ai-performance-wellness-icon-{{ ai_gen_id }},
    .ai-performance-wellness-icon-svg-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.5 }}px;
      height: {{ block.settings.icon_size | times: 0.5 }}px;
    }
  }
{% endstyle %}

<div class="ai-performance-wellness-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-performance-wellness-container-{{ ai_gen_id }}">
    <div class="ai-performance-wellness-header-{{ ai_gen_id }}">
      {% if block.settings.kicker != blank %}
        <p class="ai-performance-wellness-kicker-{{ ai_gen_id }}">{{ block.settings.kicker }}</p>
      {% endif %}

      {% if block.settings.heading != blank %}
        <h2 class="ai-performance-wellness-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.subheading != blank %}
        <p class="ai-performance-wellness-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
      {% endif %}

      {% if block.settings.body_text != blank %}
        <div class="ai-performance-wellness-body-{{ ai_gen_id }}">{{ block.settings.body_text }}</div>
      {% endif %}
    </div>

    {% assign features_count = 0 %}
    {% for i in (1..8) %}
      {% assign feature_enabled_key = 'feature_' | append: i | append: '_enabled' %}
      {% if block.settings[feature_enabled_key] %}
        {% assign features_count = features_count | plus: 1 %}
      {% endif %}
    {% endfor %}

    {% if features_count > 0 %}
      <ul class="ai-performance-wellness-features-{{ ai_gen_id }}" role="list">
        {% for i in (1..8) %}
          {% liquid
            assign feature_enabled_key = 'feature_' | append: i | append: '_enabled'
            assign feature_icon_key = 'feature_' | append: i | append: '_icon'
            assign feature_svg_key = 'feature_' | append: i | append: '_svg'
            assign feature_title_key = 'feature_' | append: i | append: '_title'
            assign feature_description_key = 'feature_' | append: i | append: '_description'

            assign feature_enabled = block.settings[feature_enabled_key]
            assign feature_icon = block.settings[feature_icon_key]
            assign feature_svg = block.settings[feature_svg_key]
            assign feature_title = block.settings[feature_title_key]
            assign feature_description = block.settings[feature_description_key]
          %}

          {% if feature_enabled %}
            <li class="ai-performance-wellness-feature-{{ ai_gen_id }}">
              <div class="ai-performance-wellness-icon-wrapper-{{ ai_gen_id }}">
                {% if feature_svg != blank %}
                  <div class="ai-performance-wellness-icon-svg-{{ ai_gen_id }}">{{ feature_svg }}</div>
                {% elsif feature_icon != blank %}
                  <img
                    src="{{ feature_icon | image_url: width: 100 }}"
                    alt="{{ feature_title | escape }}"
                    class="ai-performance-wellness-icon-{{ ai_gen_id }}"
                    loading="lazy"
                    width="100"
                    height="100"
                  >
                {% else %}
                  <div class="ai-performance-wellness-icon-svg-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10"/>
                      <path d="m9 12 2 2 4-4"/>
                    </svg>
                  </div>
                {% endif %}
              </div>

              {% if feature_title != blank %}
                <h3 class="ai-performance-wellness-feature-title-{{ ai_gen_id }}">{{ feature_title }}</h3>
              {% endif %}

              {% if feature_description != blank %}
                <p class="ai-performance-wellness-feature-description-{{ ai_gen_id }}">{{ feature_description }}</p>
              {% endif %}
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    {% endif %}
  </div>
</div>

