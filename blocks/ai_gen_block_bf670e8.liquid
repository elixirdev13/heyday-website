{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-wellness-section-{{ ai_gen_id }} {
    background-image: url('{{ block.settings.background_image | image_url: width: 2000 }}');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    padding: {{ block.settings.section_padding }}px;
    margin: 0;
  }

  .ai-wellness-container-inner-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    border-radius: {{ block.settings.inner_border_radius_top }}px {{ block.settings.inner_border_radius_right }}px {{ block.settings.inner_border_radius_bottom }}px {{ block.settings.inner_border_radius_left }}px;
    background-color: {{ block.settings.inner_background_color }};
    padding: {{ block.settings.inner_padding_vertical }}px {{ block.settings.inner_padding_horizontal }}px;
    gap: {{ block.settings.content_gap }}px;
    border: {{ block.settings.inner_border_width }}px solid {{ block.settings.inner_border_color }};
    width: 100%;
    
    {% if block.settings.center_content %}
      justify-content: center;
      text-align: center;
      flex-direction: column;
    {% else %}
      justify-content: space-between;
    {% endif %}
  }

  .ai-wellness-content-left-{{ ai_gen_id }} {
    {% unless block.settings.center_content %}
      flex: 1;
    {% endunless %}
    
  }

  .ai-wellness-heading-{{ ai_gen_id }} {
    font-weight: {{ block.settings.heading_font_weight }};
    font-size: {{ block.settings.heading_size }}px;
    font-family: {{ block.settings.heading_font_family }}, {{ settings.type_header_font_family.family }}, {{ settings.type_header_font_family.fallback_families }};
    text-transform: {{ block.settings.heading_text_transform }};
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.text_spacing }}px;
    line-height: 1.2;
  }

  .ai-wellness-text-{{ ai_gen_id }} {
    font-family: {{ settings.type_base_font_family.family }}, {{ settings.type_base_font_family.fallback_families }};
    font-weight: {{ block.settings.text_font_weight }};
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0 0 {{ block.settings.button_spacing }}px;
    {% unless block.settings.center_content %}
      padding-right: {{ block.settings.text_padding_right }}px;
    {% endunless %}
  }

  .ai-wellness-content-right-{{ ai_gen_id }} {
    {% if block.settings.center_content %}
      margin-top: {{ block.settings.button_spacing }}px;
    {% endif %}
      display: flex;
    gap: 20px;
  }

  .ai-wellness-button-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.button_width }}px;
    text-align: center;
    background-color: {{ block.settings.button_primary_bg }};
    text-decoration: none;
    color: {{ block.settings.button_primary_text_color }};
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-family: {{ settings.type_base_font_family.family }}, {{ settings.type_base_font_family.fallback_families }};
    font-weight: {{ settings.type_base_font_family.weight }};
    font-size: {{ block.settings.button_text_size }}px;
    transition: all 0.3s ease;
    border: none;
    {% if block.settings.center_content %}
      margin: 0 auto;
    {% endif %}
  }

  .ai-wellness-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_primary_hover_bg }};
    color: {{ block.settings.button_primary_hover_text }};
    text-decoration: none;
  }

  .ai-wellness-button-secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_secondary_bg }};
    color: {{ block.settings.button_secondary_text_color }};
    border: {{ block.settings.button_secondary_border_width }}px solid {{ block.settings.button_secondary_border }};
   
  }

  .ai-wellness-button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_secondary_hover_bg }};
    color: {{ block.settings.button_secondary_hover_text }};
    border-color: {{ block.settings.button_secondary_hover_border }};
  }

  @media screen and (max-width: 749px) {
    .ai-wellness-content-right-{{ ai_gen_id }} {
      flex-direction: column;
    }
    .ai-wellness-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.5 }}px;
      background-image: url('{{ block.settings.background_image | image_url: width: 1000 }}');
    }

    .ai-wellness-container-inner-{{ ai_gen_id }} {
      flex-direction: column;
      text-align: center;
      padding: {{ block.settings.inner_padding_vertical | times: 0.7 }}px {{ block.settings.inner_padding_horizontal | times: 0.7 }}px;
      border-radius: {{ block.settings.inner_border_radius_top | times: 0.6 }}px {{ block.settings.inner_border_radius_right | times: 0.6 }}px {{ block.settings.inner_border_radius_bottom | times: 0.6 }}px {{ block.settings.inner_border_radius_left | times: 0.6 }}px;
    }

    .ai-wellness-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-wellness-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
      padding-right: 0;
    }

    .ai-wellness-button-{{ ai_gen_id }} {
      width: 100%;
      max-width: {{ block.settings.button_width }}px;
    }
  }
{% endstyle %}

<div class="ai-wellness-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-wellness-container-inner-{{ ai_gen_id }}">
    <div class="ai-wellness-content-left-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h4 class="ai-wellness-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h4>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-wellness-text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
      {% endif %}
    </div>

    <div class="ai-wellness-content-right-{{ ai_gen_id }}">
      {% if block.settings.button_primary_text != blank and block.settings.button_primary_url != blank %}
        <a 
         id="btn-shop-now-2"
          href="{{ block.settings.button_primary_url }}" 
          class="ai-wellness-button-{{ ai_gen_id }}"
        >
          {{ block.settings.button_primary_text }}
        </a>
      {% endif %}

      {% if block.settings.button_secondary_text != blank and block.settings.button_secondary_url != blank %}
        <a 
          href="{{ block.settings.button_secondary_url }}" 
          class="ai-wellness-button-{{ ai_gen_id }} ai-wellness-button-secondary-{{ ai_gen_id }}"
        >
          {{ block.settings.button_secondary_text }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const btn3 = document.getElementById('btn-shop-now-2');
  
  const section3 = document.getElementById('shopify-section-template--20033894056188__featured_collection_wVwHkG');
  if (!btn3 || !section3) return;
 

  btn3.addEventListener('click', function (e) {
    e.preventDefault();
    section3.scrollIntoView({ behavior: 'smooth' });
  });


});
</script>

