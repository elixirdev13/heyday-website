<style>
/* MAIN WRAPPER */
.fold-5 {
    width: 100%;
    padding: 100px 0 0 0;
}

.fold-5 .title {
    text-align: center;
    margin-bottom: 30px;
}

/* CAROUSEL */
.carousel-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
    height: 650px;
}

.carousel-track {
    display: flex;
    transition: transform 0.6s ease;
}

.carousel-slide {
    min-width: 100%;
    height: 100%;
    position: relative;
    display: block;
    cursor: pointer;
}

.carousel-slide img {
    width: 100%;
    height: 650px;
    object-fit: cover;
    background-position: center;
}

/* CARD — fixed to lower right */
.slide-card {
    position: absolute;
    bottom: 40px;
    right: 40px;
    width: 575px;
    background: #ffffff;
    padding: 20px;
    border-radius: 6px;
    box-shadow: 0 8px 25px rgba(0,0,0,0.15);
    z-index: 5;
}

.slide-card h3 {
    margin: 0 0 8px;
    font-size: 32px;
    font-weight: 800;
}

.slide-card p {
    margin: 0 0 16px;
    font-size: 24px;
    line-height: normal;
}

.slide-card a.inside-btn {
  background: #123d21;
  color: #fff;
  border: none;
  padding: 8px 70px;
  border-radius: 22px;
  cursor: pointer;
  font-weight: 600;
  text-decoration: none;
  display: inline-block;
  font-size: 18px;
}

/* DOTS */
.carousel-dots {
    display: flex;
    justify-content: center;
    margin-top: 15px;
    gap: 8px;
}

.dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #bbb;
    cursor: pointer;
}

.dot.active {
    background: #333;
}

/* -------------------------------------------------- */
/* RESPONSIVE                                        */
/* -------------------------------------------------- */

/* TABLETS */
@media (max-width: 992px) {
    .carousel-wrapper { height: 500px; }
    .slide-card { width: 420px; bottom: 30px; right: 30px; padding: 18px; }
    .slide-card h3 { font-size: 20px; }
    .slide-card p { font-size: 18px; }
}

/* SMALL TABLETS */
@media (max-width: 768px) {
    .carousel-wrapper { height: 380px; }
    .slide-card { width: 320px; bottom: 25px; right: 20px; padding: 16px; text-align:center; }
    .slide-card h3 { font-size: 18px; }
    .slide-card p { font-size: 16px; }
    .fold-5{
      padding: 60px 20px 0 20px;
    }
    
}

/* MOBILE */
@media (max-width: 560px) {
    .carousel-wrapper { height: auto; }
    .carousel-slide { height: auto; }
    .carousel-slide img { height: 260px; }
    .slide-card {
        position: relative;
        bottom: auto;
        right: auto;
        width: 100%;
        margin-top: -20px;
        border-radius: 0;
        box-shadow: none;
        padding: 20px;
    }
    .slide-card h3 { font-size: 20px; }
    .slide-card p { font-size: 16px; }
    .slide-card a.inside-btn { font-size: 14px; padding: 10px 20px; }
}
</style>

<div class="fold-5">
    <div class="title">
        <h2>{{ section.settings.header }}</h2>
        <p>{{ section.settings.subheader }}</p>
    </div>

    <!-- PURE JS Carousel -->
    <div class="carousel-wrapper">
        <div class="carousel-track">
            {% for block in section.blocks %}
            <div class="carousel-slide" data-link="{{ block.settings.slide_link }}">
                <img src="{{ block.settings.image | img_url: 'master' }}">
                
                <div class="slide-card">
                    <h3>{{ block.settings.card_title }}</h3>
                    <p>{{ block.settings.card_text }}</p>

                    {% if block.settings.button_text != blank %}
                    <a href="{{ block.settings.button_link }}" class="inside-btn">
                        {{ block.settings.button_text }}
                    </a>
                    {% endif %}
                </div>
            </div>
            {% endfor %}
        </div>
    </div>

    <div class="carousel-dots">
        {% for block in section.blocks %}
        <div class="dot" data-index="{{ forloop.index0 }}"></div>
        {% endfor %}
    </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", () => {
    const track = document.querySelector('.carousel-track');
    const slides = Array.from(document.querySelectorAll('.carousel-slide'));
    const dots = Array.from(document.querySelectorAll('.dot'));

    let index = 0;
    const total = slides.length;

    function updateCarousel() {
        track.style.transform = `translateX(-${index * 100}%)`;
        dots.forEach(dot => dot.classList.remove('active'));
        dots[index].classList.add('active');
    }

    // Auto-slide every 4s
    let autoSlide = setInterval(() => {
        index = (index + 1) % total;
        updateCarousel();
    }, 4000);

    // Dot click
    dots.forEach(dot => {
        dot.addEventListener('click', () => {
            index = Number(dot.dataset.index);
            updateCarousel();
            clearInterval(autoSlide);
        });
    });

    // Make slide clickable
    slides.forEach(slide => {
        slide.addEventListener('click', e => {
            if (!e.target.closest('.inside-btn')) { // ignore clicks on the button
                const link = slide.dataset.link;
                if (link) window.location.href = link;
            }
        });
    });

    updateCarousel();
});
</script>

{% schema %}
{
  "name": "Perfect Gift Carousel",
  "settings": [
    {
      "type": "text",
      "label": "Header",
      "id": "header"
    },
    {
      "type": "text",
      "label": "Subheader",
      "id": "subheader"
    }
  ],

  "blocks": [
    {
      "type": "slide",
      "name": "Slide Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Upload Slide Image"
        },
        {
          "type": "url",
          "id": "slide_link",
          "label": "Slide Link",
          "info": "Makes the entire slide clickable"
        },
        {
          "type": "text",
          "id": "card_title",
          "label": "Card Title",
          "default": "For Family"
        },
        {
          "type": "textarea",
          "id": "card_text",
          "label": "Card Description",
          "default": "Wholesome treats and essentials for memorable shared meals."
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Shop This Collection"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],

  "presets": [
    {
      "name": "Perfect Gift Carousel"
    }
  ]
}
{% endschema %}
