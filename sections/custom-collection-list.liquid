<style>
  #shopify-section-{{ section.id }} .collection-list {
    padding-block: 5rem;
  }
  #shopify-section-{{ section.id }} .collection-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
    justify-content: center;
  }
  #shopify-section-{{ section.id }} .collection-item {
    text-align: center;
  }
  #shopify-section-{{ section.id }} .collection-item img {
    max-width: 100%;
    height: 330px;
    border-radius: 10px;
  }
  #shopify-section-{{ section.id }} h1 {
    font-size: 2em;
    font-weight: 400;
    margin-bottom: 30px;
    color: #2f4f2f;
    font-family: "MajesticKingdome";
    text-align: center;

  }
  #shopify-section-{{ section.id }} h2 {
    font-size: 1.4em;
    font-weight: 700;
    margin-top: 15px;
  }
</style>

<div class="page-width collection-list">
  <h1>{{ section.settings.title }}</h1>
  <div class="collection-grid">
    {% for block in section.blocks %}
      <div class="collection-item">
        <a href="{{ block.settings.collection_link }}">
          <img
            src="{{ block.settings.collection_image | img_url: 'master' }}"
            alt="{{ block.settings.collection_title }}"
          >
          <h2>{{ block.settings.collection_title }}</h2>
        </a>
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Collection List",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Shop All"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "url",
          "id": "collection_link",
          "label": "Collection Link"
        },
        {
          "type": "text",
          "id": "collection_title",
          "label": "Collection Title"
        },
        {
          "type": "image_picker",
          "id": "collection_image",
          "label": "Collection Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Collection List",
      "category": "Custom"
    }
  ]
}
{% endschema %}
