<style>
.belief-section {
  padding: 20px;
}

.belief-container {
  max-width: 1300px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  align-items: stretch;
}

.belief-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 12px;
}


@media (max-width: 900px) {
  .belief-container {
    grid-template-columns: 1fr;
  }

}
</style>

<section class="belief-section" style="background-color: {{ section.settings.background_color }}">
  <div class="belief-container">
    <div class="belief-image">
      {% if section.settings.image1 != blank %}
        <img
          src="{{ section.settings.image1 | image_url: width: 1200 }}"
          alt="{{ section.settings.image2.alt | escape }}"
          loading="lazy"
        >
      {% else %}
        {{ 'image' | placeholder_svg_tag }}
      {% endif %}
    </div>

      <div class="belief-image">
      {% if section.settings.image2 != blank %}
        <img
          src="{{ section.settings.image2 | image_url: width: 1200 }}"
          alt="{{ section.settings.image2.alt | escape }}"
          loading="lazy"
        >
      {% else %}
        {{ 'image' | placeholder_svg_tag }}
      {% endif %}
    </div>
    
  </div>
</section>

{% schema %}
{
  "name": "Image with Belief Content",
  "settings": [
    {
      "type": "image_picker",
      "id": "image1",
      "label": "Image"
    },
    {
      "type": "image_picker",
      "id": "image2",
      "label": "Image"
    }
  ],
  "presets": [
    {
      "name": "Custom Image with Content",
      "category": "Custom"
    }
  ]
}
{% endschema %}
