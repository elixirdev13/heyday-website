<style>
  /* Use Liquid variables for colors so they are editable */
  #shopify-section-{{ section.id }} .icon-section {
    background: {{ section.settings.background_color }};
    padding: 80px 100px;
    height: 100%;
  }

  #shopify-section-{{ section.id }} .header-container h2 {
    font-size: 36px;
    color: {{ section.settings.heading_color }};
    margin: 0 0 25px;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .header-container p {
    margin: 0;
    font-size: 16px;
    color: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .content-container h4 {
    font-size: 24px;
    color: {{ section.settings.heading_color }};
    font-weight: 500;
    margin-bottom: 10px;
  }

  #shopify-section-{{ section.id }} .content-container p {
    font-size: 16px;
    color: {{ section.settings.text_color }};
    margin: 0;
    line-height: normal;
    font-weight: normal;
  }

  .header-container {
    text-align: center;
    margin-bottom: 50px;
  }

  .cards-container {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    justify-items: center;
    text-align: center;
    max-width: 1400px;
    margin: 0 auto;
  }

  .card {
    max-width: 310px;
    padding: 20px;
    width: 100%; 
  }

  .icon-container {
    margin-bottom: 20px;
  }

  .icon-container img,
  .icon-container svg {
    width: 105px;
    height: 80px;
    object-fit: contain;
    padding: 10px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Responsive Styles */
  @media (max-width: 1024px) {
    #shopify-section-{{ section.id }} .icon-section {
      padding: 60px 40px;
    }
    #shopify-section-{{ section.id }} .header-container h2 {
      font-size: 30px;
    }
    .cards-container {
      grid-template-columns: repeat(2, 1fr); 
    }
  }

  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .icon-section {
      padding: 40px 20px;
    }
    #shopify-section-{{ section.id }} .header-container h2 {
      font-size: 26px;
    }
    .cards-container {
      grid-template-columns: 1fr;
      gap: 30px;
    }
    .card {
      max-width: 100%;
    }
  }

  @media (max-width: 480px) {
    #shopify-section-{{ section.id }} .header-container h2 {
      font-size: 22px;
    }
    .icon-container img,
    .icon-container svg {
      width: 70px;
      height: 70px;
    }
    #shopify-section-{{ section.id }} .content-container h4 {
      font-size: 18px;
    }
    #shopify-section-{{ section.id }} .content-container p {
      font-size: 13px;
    }
  }
</style>

<div class="icon-section">
  <div class="header-container">
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p>{{ section.settings.subheading }}</p>
    {% endif %}
  </div>

  <div class="cards-container">
    {% for block in section.blocks %}
      <div class="card" {{ block.shopify_attributes }}>
        <div class="icon-container">
          {% if block.settings.image != blank %}
            <img 
              src="{{ block.settings.image | image_url: width: 300 }}" 
              alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
              width="105"
              height="80"
              loading="lazy">
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>
        <div class="content-container">
          {% if block.settings.title != blank %}
            <h4 class="title">{{ block.settings.title }}</h4>
          {% endif %}
          {% if block.settings.subtitle != blank %}
            <p class="subtitle">{{ block.settings.subtitle }}</p>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Highlights",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Highlights"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Add a description here"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#FF7933"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#333333"
    }
  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "Highlight",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Short description of this feature."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Icons section",
      "blocks": [
        {
          "type": "highlight"
        },
        {
          "type": "highlight"
        },
        {
          "type": "highlight"
        },
        {
          "type": "highlight"
        }
      ]
    }
  ]
}
{% endschema %}