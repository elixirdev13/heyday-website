<style>
  #shopify-section-{{ section.id }} .category-cards-section {
      text-align: center;
      padding: 50px 20px;
      background-color: #f8f8f8;
  }

  #shopify-section-{{ section.id }} .category-cards-title {
      font-size: 2em;
      font-weight: 400;
      margin-bottom: 30px;
      color: #2f4f2f;
      font-family: "MajesticKingdome";
  }

  #shopify-section-{{ section.id }} .category-cards-container {
      display: flex;
      justify-content: center;
      gap: 20px;
      flex-wrap: wrap;
  }

  #shopify-section-{{ section.id }} .category-card {
      background-color: #ffffff;
      border-radius: 10px;
      overflow: hidden;
      width: 180px;
      height: 180px;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
      transition: transform 0.3s ease-in-out, box-shadow 0.3s ease-in-out;
      position: relative;
  }

  #shopify-section-{{ section.id }} .category-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 6px 12px rgba(0, 0, 0, 0.2);
  }

  #shopify-section-{{ section.id }} .category-card__image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      position: absolute;
      top: 0;
      left: 0;
      z-index: 1;
      /* opacity: 0.8; */
  }

  #shopify-section-{{ section.id }} .category-card__content {
      z-index: 2;
      position: relative;
      color: #fff;
      font-size: 1em;
      font-weight: bold;
      padding: 10px;
      text-shadow: 0 2px 4px rgba(0, 0, 0, 0.6);
      font-family: "MajesticKingdome";
  }
  @media (max-width:768px){
    #shopify-section-{{ section.id }} .category-card {
      width: 150px;
      height: 150px;
    }
  }
</style>

<div class="category-cards-section">
  <h2 class="category-cards-title">{{ section.settings.title }}</h2>
  <div class="category-cards-container">
    {% for block in section.blocks %}
      <a href="{{ block.settings.link }}" class="category-card">
        <img
          src="{{ block.settings.image | img_url: '300x300' }}"
          alt="{{ block.settings.title }}"
          class="category-card__image"
        >
        <div class="category-card__content">{{ block.settings.title }}</div>
      </a>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Category Cards",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "What are you looking for?"
    }
  ],
  "blocks": [
    {
      "type": "category_card",
      "name": "Category Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Category Title",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Category Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Cards",
      "category": "Custom"
    }
  ]
}
{% endschema %}
