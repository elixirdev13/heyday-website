<style>
  /* Section Padding & Background */
  #shopify-section-{{ section.id }} .perfect-fit-section {
    padding: 60px 20px;
    background-color: {{ section.settings.bg_color }};
  }

  /* Section Heading */
  #shopify-section-{{ section.id }} .section-title {
    text-align: center;
    font-size: 38px;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin-bottom: 40px;
  }

  /* Grid Layout */
  .fit-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Individual Card */
  .fit-card {
    position: relative;
    display: block;
    width: 100%;
    overflow: hidden;
    text-decoration: none;
  }

  /* Aspect Ratio & Image */
  .image-container {
    position: relative;
    width: 100%;
    background-color: #f0f0f0;
    padding-bottom: 75%; /* Sets the height of the card */
    overflow: hidden;
  }

  /* Gradient Overlay - Desktop (Bottom Fade) */
  .image-container::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 60%;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 100%);
    z-index: 1;
    transition: opacity 0.3s ease;
  }

  .image-container img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  /* Zoom effect on hover */
  .fit-card:hover .image-container img {
    transform: scale(1.05);
  }

  /* Positioning Text over Image */
  .fit-content {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 25px;
    z-index: 2; /* Sits above the gradient */
    box-sizing: border-box;
    /* Default alignment for desktop */
    text-align: left; 
  }

  .fit-content h3 {
    color: #ffffff;
    font-size: 24px;
    font-weight: 700;
    margin: 0 0 5px 0;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .fit-content p {
    color: #ffffff;
    font-size: 24px;
    margin: 0;
    opacity: 0.9;
    font-weight: 400;
  }

  /* --- Mobile & Tablet Responsive Updates --- */
  
  /* Applies to Tablets (1024px) and smaller */
  @media (max-width: 1024px) {
    
    /* Center the text content vertically and horizontally */
    .fit-content {
      top: 50%;           /* Push top edge to middle */
      bottom: auto;       /* Reset bottom positioning */
      transform: translateY(-50%); /* Pull back up by half its height to center perfectly */
      text-align: center; /* Center the text lines */
      padding: 20px;
    }
    
    /* Change overlay to full coverage so white text is readable in the center */
    .image-container::after {
      height: 100%;
      background: rgba(0, 0, 0, 0.3); /* Semi-transparent black over whole image */
    }
  }

  /* Applies specifically to Phones (768px) and smaller */
  @media (max-width: 768px) {
    .fit-grid {
      grid-template-columns: 1fr; /* Stack vertically on phones */
      gap: 15px;
    }
    
    .section-title {
      font-size: 28px;
    }

    .image-container {
      padding-bottom: 65%;
    }

    .fit-content h3 {
      font-size: 20px;
    }
    .fit-content p {
      font-size: 16px; /* Adjusted size for better mobile readability */
    }
  }
</style>

<div class="perfect-fit-section">
  {% if section.settings.heading != blank %}
    <h2 class="section-title">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="fit-grid">
    {% for block in section.blocks %}
      <a href="{{ block.settings.link }}" class="fit-card" {{ block.shopify_attributes }}>
        <div class="image-container">
          {% if block.settings.image != blank %}
            <img 
              src="{{ block.settings.image | image_url: width: 800 }}" 
              alt="{{ block.settings.title | escape }}" 
              loading="lazy"
              width="800"
              height="600">
          {% else %}
            {{ 'collection-1' | placeholder_svg_tag }}
          {% endif %}
        </div>
        
        <div class="fit-content">
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.subtitle }}</p>
        </div>
      </a>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Perfect Fit Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Find Your Perfect Fit"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1B4D3E"
    }
  ],
  "blocks": [
    {
      "type": "category_card",
      "name": "Category Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Energy & Immunity"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Vitamin C, Multivitamins"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Link to the collection or page"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Perfect Fit Grid",
      "category": "Custom",
      "blocks": [
        { "type": "category_card" },
        { "type": "category_card" },
        { "type": "category_card" },
        { "type": "category_card" }
      ]
    }
  ]
}
{% endschema %}