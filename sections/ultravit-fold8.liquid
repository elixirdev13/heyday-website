<style>
  /* Outer container with the background image */
  #shopify-section-{{ section.id }} .cta-section-container {
    padding: 60px 20px;
    /* Use the uploaded image or a fallback color */
    background-image: url('{{ section.settings.background_image | image_url: width: 1600 }}');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-color: {{ section.settings.bg_fallback_color }};
  }

  /* The white, shaped banner */
  .cta-banner {
    padding: 40px 10px;
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  /* Heading style */
  .cta-heading {
    font-size: 42px;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin: 0;
  }

  /* Button style */
  .cta-button {
    display: inline-block;
    background-color: {{ section.settings.button_color }};
    color: {{ section.settings.button_text_color }};
    padding: 8px 40px;
    border-radius: 50px; /* Pill shape */
    text-decoration: none;
    font-weight: 700;
    font-size: 16px;
    transition: opacity 0.3s ease;
    white-space: nowrap; /* Keeps button text on one line */
  }

  .cta-button:hover {
    opacity: 0.9;
  }

  /* Mobile Responsiveness */
  @media (max-width: 768px) {
    .cta-banner {
      flex-direction: column;
      text-align: center;
      padding: 40px 30px;
      /* Adjust shape for mobile if needed, or keep it */
      border-radius: 40px 0 40px 0;
      gap: 30px;
    }

    .cta-heading {
      font-size: 32px;
    }

    .cta-button {
      width: 100%; /* Full width button on mobile */
      max-width: 300px;
    }
  }
</style>

<div class="cta-section-container">
  <div class="cta-banner">
    {% if section.settings.heading != blank %}
      <h2 class="cta-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    
    {% if section.settings.button_text != blank and section.settings.button_link != blank %}
      <a href="{{ section.settings.button_link }}" class="cta-button">
        {{ section.settings.button_text }}
      </a>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "CTA Banner",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Boost Your Day The Ultravit Way"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Label",
      "default": "Shop Ultravit Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Section Background Image",
      "info": "Upload the grid pattern image here."
    },
    {
      "type": "color",
      "id": "bg_fallback_color",
      "label": "Fallback Background Color",
      "default": "#FFF5E6",
      "info": "Shown if no image is uploaded."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1B4D3E"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Background Color",
      "default": "#F27D42"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "CTA Banner",
      "category": "Custom"
    }
  ]
}
{% endschema %}