<style>
    .christmas-cta {
        padding: 100px 60px;
        background-image: url({{ section.settings.bg_image | img_url: 'master' }});
        background-size: cover;
        background-position: center;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .cta-container {
        display:flex;
        flex-direction:column;
        justify-content:center;
        align-items:center;
        text-align:center;
    }

    .text-container h1 {
        color: white;
        font-size: 32px;
        font-weight: 400;
    }

    .text-container h3 {
        color: white;
        font-size: 24px;
        font-weight: normal;
        max-width:800px;
        margin: 0 auto;
    }

    .button-container a.cta-btn {
        display: inline-block;
        padding: 8px 50px;
        background: #FDD71B;
        color: black;
        text-decoration: none;
        border-radius: 22px;
        font-size: 16px;
        font-weight:bold;
        margin-top: 20px;
    }

    /* ----------------------------- */
    /*     MOBILE BACKGROUND IMAGE   */
    /* ----------------------------- */
    @media (max-width: 768px) {
        .christmas-cta {
            background-image: url({{ section.settings.bg_image_mobile | img_url: 'master' }});
            padding: 60px 20px;
        }

        .text-container h1{
            font-size: 26px;
        }

        .text-container h3{
            font-size: 18px;
        }

        .button-container a.cta-btn{
            font-size: 16px;
            padding: 10px 22px;
        }
    }

    @media (max-width: 480px){
        .christmas-cta {
            padding: 40px 16px;
        }

        .text-container h1{
            font-size: 22px;
        }

        .text-container h3{
            font-size: 16px;
        }

        .button-container a.cta-btn{
            width: 100%;
            max-width: 260px;
            padding: 12px;
        }
    }
</style>

<div class="christmas-cta">
    <div class="cta-container">

        <div class="text-container">
            <h1>{{ section.settings.header }}</h1>
            <h3>{{ section.settings.subheader }}</h3>
        </div>

        <div class="button-container">
            <a href="{{ section.settings.button_link }}" class="cta-btn">
                {{ section.settings.button_text }}
            </a>
        </div>

    </div>
</div>

{% schema %}
{
    "name": "Christmas CTA 1",
    "settings": [
        {
            "type": "image_picker",
            "label": "Desktop Background Image",
            "id": "bg_image"
        },
        {
            "type": "image_picker",
            "label": "Mobile Background Image",
            "id": "bg_image_mobile"
        },
        {
            "type": "text",
            "label": "Header",
            "id": "header",
        },
        {
            "type": "text",
            "label": "Subheader",
            "id": "subheader",

        },
        {
            "type": "text",
            "label": "Button Text",
            "id": "button_text",
            "default": "Shop Now"
        },
        {
            "type": "url",
            "label": "Button Link",
            "id": "button_link"
        }
    ],
    "presets": [
        {
            "name": "Christmas CTA 1"
        }
    ]
}
{% endschema %}
